# shellcheck disable=SC2209 # modules_shell holds a literal shell name, not a command
case "$0" in
-sh | sh | */sh) modules_shell=sh ;;
-ksh | ksh | */ksh) modules_shell=ksh ;;
-zsh | zsh | */zsh) modules_shell=zsh ;;
-bash | bash | */bash) modules_shell=bash ;;
esac
module() { eval "$(/usr/bin/tclsh /usr/share/Modules/libexec/modulecmd.tcl "$modules_shell" "$*")"; }

# Source global definitions
if [ "$modules_shell" = "zsh" ] && [ -f /etc/zshrc ]; then
  # shellcheck disable=SC1091
  . /etc/zshrc
elif [ "$modules_shell" = "bash" ] && [ -f /etc/bashrc ]; then
  # shellcheck disable=SC1091
  . /etc/bashrc
fi

TERM=screen-256color

alias ls='ls --color'

export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
# shellcheck disable=SC2034
force_color_prompt=yes

# shellcheck disable=SC1091
[ -f ~/.fzf.bash ] && source "$HOME/.fzf.bash"

if type -a fzf &>/dev/null; then
  eval "$(fzf --bash)"
fi

{{- if eq .chezmoi.os "darwin" }}
[ -f "/opt/homebrew/bin/brew" ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -f "/usr/local/bin/brew" ] && eval "$(/usr/local/bin/brew shellenv)"
{{- else }}
[ -f "/home/linuxbrew/.linuxbrew/bin/brew" ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- end }}

# shellcheck disable=SC1091
[ -f ~/.cargo/env ] && source "$HOME/.cargo/env"
